#!/usr/bin/env bash
# hermesctl — operate the Hermes sandbox as if it were a normal CLI install.
#
# GENERATED by deploy.sh (step_hermesctl) from assets/hermesctl.tmpl — DO NOT EDIT
# IN PLACE; re-run `./deploy.sh hermesctl --yes` to regenerate (e.g. after a uid change).
#
# Hermes actually runs as a rootless Podman container owned by the system user
# '@@HERMES_USER@@' (uid @@HERMES_UID@@) under `systemctl --user`, and the Hermes CLI
# lives INSIDE that container. This wrapper hides both: a few management verbs the
# Hermes CLI lacks (restart/start/stop/journal/help), and everything else passes
# through to the in-container CLI — so `hermesctl status|logs|model|doctor|...`
# behaves like a local install. Self-elevates via sudo; run it as your admin user.
set -euo pipefail

HERMES_USER="@@HERMES_USER@@"; HERMES_UID="@@HERMES_UID@@"
SERVICE_NAME="@@SERVICE_NAME@@"; CONTAINER="@@CONTAINER@@"
RUNTIME_DIR="/run/user/${HERMES_UID}"; DBUS_ADDR="unix:path=${RUNTIME_DIR}/bus"

# Run a command in the hermes user's systemd/dbus session. chdir=/ because the
# caller's cwd (e.g. ~ubuntu, mode 750) is unreadable to the hermes uid. Skips the
# sudo hop if already running as hermes.
_as_hermes() {
  if [ "$(id -un)" = "${HERMES_USER}" ]; then
    env --chdir=/ "XDG_RUNTIME_DIR=${RUNTIME_DIR}" "DBUS_SESSION_BUS_ADDRESS=${DBUS_ADDR}" "$@"
  else
    sudo -u "${HERMES_USER}" env --chdir=/ \
      "XDG_RUNTIME_DIR=${RUNTIME_DIR}" "DBUS_SESSION_BUS_ADDRESS=${DBUS_ADDR}" "$@"
  fi
}

# -it only when both stdin and stdout are TTYs, so piping/cron stays clean.
_exec_flags() { if [ -t 0 ] && [ -t 1 ]; then printf -- '-it'; else printf -- '-i'; fi; }

usage() {
  cat <<EOF
hermesctl — operate the Hermes sandbox as if it were a normal CLI install.
  restart | start | stop    service control
  journal [args]            host journal for the unit (sudo; default: follow)
  help                      this text
Anything else is forwarded to the in-container Hermes CLI, e.g.:
  hermesctl status      hermesctl logs       hermesctl model ...      hermesctl doctor
EOF
}

main() {
  local verb="${1:-help}" flags
  case "${verb}" in
    restart|start|stop)
      shift; _as_hermes systemctl --user "${verb}" "${SERVICE_NAME}" "$@" ;;
    journal)
      shift
      if [ "$#" -eq 0 ]; then
        sudo journalctl "_SYSTEMD_USER_UNIT=${SERVICE_NAME}" -f
      else
        sudo journalctl "_SYSTEMD_USER_UNIT=${SERVICE_NAME}" "$@"
      fi ;;
    help|-h|--help)
      usage ;;
    *)
      flags="$(_exec_flags)"
      _as_hermes podman exec "${flags}" "${CONTAINER}" hermes "$@" ;;
  esac
}

main "$@"
